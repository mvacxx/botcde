<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Painel do Bot</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; background: #0f172a; color: #e2e8f0; }
    .card { max-width: 740px; margin: 0 auto; background: #1e293b; border-radius: 12px; padding: 1.5rem; }
    h1 { margin-top: 0; }
    .meta { color: #94a3b8; margin-bottom: 1rem; }
    .switch { display: flex; align-items: center; gap: 0.6rem; margin: 0.8rem 0; }
    button { margin-top: 1rem; padding: 0.6rem 1rem; border: 0; border-radius: 8px; background: #3b82f6; color: white; cursor: pointer; }
    button:hover { background: #2563eb; }
    code { background: #334155; padding: 0.1rem 0.4rem; border-radius: 4px; }
  </style>
</head>
<body>
  <main class="card">
    <h1>Painel do Discord Bot</h1>
    <p class="meta"><strong>Bot:</strong> <%= botName %></p>
    <p class="meta"><strong>Servidores:</strong> <%= guilds %></p>

    <form method="post" action="/features">
      <label class="switch">
        <input type="checkbox" name="autoRole" <%= featureFlags.autoRole ? 'checked' : '' %> />
        Ativar auto-cargo para novos membros
      </label>

      <label class="switch">
        <input type="checkbox" name="music" <%= featureFlags.music ? 'checked' : '' %> />
        Ativar comandos de música (<code>-play</code>, <code>-skip</code>, <code>-stop</code>)
      </label>

      <button type="submit">Salvar alterações</button>
    </form>
  </main>
</body>
</html>
